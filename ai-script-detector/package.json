{
  "name": "scriptlens-extension",
  "version": "0.1.0",
  "private": true,
  "description": "YouTube-only ScriptLens Chrome extension tooling, packaging, and tests.",
  "scripts": {
    "backend:start": "node backend/server.js",
    "backend:docker:build": "docker build -t scriptlens-backend .",
    "backend:smoke": "node scripts/smoke-backend.mjs",
    "backend:smoke:asr": "node scripts/smoke-backend.mjs --allow-automatic-asr",
    "build:extension": "node scripts/build-extension.mjs",
    "build:defuddle-canary": "node scripts/defuddle-canary.mjs build",
    "ci:fast": "playwright test tests/contracts.spec.js tests/inline-state.spec.js tests/service-worker-report.spec.js tests/backend-module.spec.js tests/staged-consumer-qa.spec.js tests/release-build.spec.js tests/release-readiness.spec.js tests/shared-surface.spec.js tests/service-worker.inline.spec.js tests/backend-server.spec.js tests/transcript-resolver.spec.js tests/content.youtube.spec.js --reporter=line",
    "ci:smoke": "playwright test tests/youtube.smoke.spec.js --reporter=line",
    "debug:youtube-transcript": "node scripts/debug-youtube-transcript.mjs",
    "package:extension": "node scripts/package-extension.mjs",
    "package:defuddle-canary": "node scripts/defuddle-canary.mjs package",
    "qa:defuddle": "node scripts/defuddle-video-qa.mjs",
    "qa:defuddle:backend": "node scripts/defuddle-video-qa.mjs --include-backend --backend-local",
    "qa:defuddle:canary": "node scripts/defuddle-video-qa.mjs --canary-only",
    "qa:defuddle:backend:canary": "node scripts/defuddle-video-qa.mjs --canary-only --include-backend --backend-local",
    "qa:staging": "node scripts/staged-consumer-qa.mjs",
    "qa:canary": "node scripts/staged-consumer-qa.mjs --backend-only --canary-only --require-canary --report-json release/staged-canary-report.json --report-markdown release/staged-canary-report.md",
    "release:readiness": "node scripts/release-readiness.mjs",
    "release:readiness:public": "node scripts/release-readiness.mjs --mode public",
    "test:defuddle-canary": "node scripts/defuddle-canary.mjs test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:youtube": "playwright test tests/youtube.smoke.spec.js --headed",
    "test:e2e:debug": "playwright test tests/youtube.smoke.spec.js --debug"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0"
  }
}
