{
  "name": "scriptlens-extension",
  "version": "0.1.0",
  "private": true,
  "description": "YouTube-only ScriptLens Chrome extension tooling, packaging, and tests.",
  "scripts": {
    "backend:start": "node backend/server.js",
    "backend:docker:build": "docker build -t scriptlens-backend .",
    "backend:smoke": "node scripts/smoke-backend.mjs",
    "backend:smoke:asr": "node scripts/smoke-backend.mjs --allow-automatic-asr",
    "build:extension": "node scripts/build-extension.mjs",
    "package:extension": "node scripts/package-extension.mjs",
    "qa:staging": "node scripts/staged-consumer-qa.mjs",
    "qa:canary": "node scripts/staged-consumer-qa.mjs --backend-only --canary-only --require-canary --report-json release/staged-canary-report.json --report-markdown release/staged-canary-report.md",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:youtube": "playwright test tests/youtube.smoke.spec.js --headed",
    "test:e2e:debug": "playwright test tests/youtube.smoke.spec.js --debug"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0"
  }
}
